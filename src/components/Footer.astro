---
const today = new Date();
import ColourPalette from '../components/ColourPalette.astro';
import { COMPANY_NAME, SITE_FOOTER_COL } from '../consts';
---

<footer class={`p-[1em] masterPaddingLR ${SITE_FOOTER_COL}`}>
	<div class="flex h-[18px]">
		<ColourPalette />
		<div class="grow text-right">&copy; {today.getFullYear()} {COMPANY_NAME}. All rights reserved.</div>
	</div>

</footer>
